---
const brandName = 'timproshka';
const chars = brandName.split('');
---

<div
  id="intro-overlay"
  class="fixed inset-0 z-50 flex items-center justify-center bg-bg"
>
  <h1 class="text-4xl md:text-6xl font-black uppercase tracking-[0.1em] text-ink">
    {chars.map((char) => (
      <span class="intro-char inline-block">{char}</span>
    ))}
  </h1>
</div>
