---
import { getLangFromUrl, useTranslations } from '../i18n/useTranslations';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stack = ['Astro', 'React', 'Tailwind', 'Three.js', 'GSAP', 'n8n', 'Python', 'Node.js', 'TypeScript'];
---

<section id="about" class="section-full">
  <div class="max-w-4xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
      <div class="reveal-scale">
        <div class="aspect-square rounded-card overflow-hidden border border-surface-border">
          <img
            src="/photo.jpg"
            alt={t.about.photoAlt}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <div>
        <span class="section-number reveal">{t.about.label}</span>
        <h2 class="text-3xl md:text-4xl font-black uppercase mt-3 mb-2 reveal">{t.about.name}</h2>
        <p class="text-accent font-serif italic text-lg mb-6 reveal">{t.about.role}</p>

        <div class="space-y-4 text-ink-soft leading-relaxed">
          <p class="reveal">{t.about.p1}</p>
          <p class="reveal">{t.about.p2}</p>
        </div>

        <div class="mt-8 reveal">
          <span class="text-xs font-mono font-bold uppercase tracking-widest text-ink-muted mb-4 block">{t.about.stackLabel}</span>
          <div class="flex flex-wrap gap-2" data-stagger>
            {stack.map((name) => (
              <span class="px-3 py-1.5 text-xs font-mono font-semibold uppercase tracking-wider border border-surface-border rounded-full text-ink-soft hover:bg-accent hover:text-white hover:border-accent transition-all duration-200">
                {name}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
