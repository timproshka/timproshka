---
const words = 'Ваш сайт не приносит клиентов? Исправим за 14 дней'.split(' ');
---

<section id="hero" class="section-full relative overflow-hidden">
  <!-- Side decoration (silencio.es style) -->
  <div class="side-text hidden lg:block">timproshka &reg;</div>

  <div class="max-w-6xl mx-auto px-6 text-center">
    <!-- Main heading with word reveal -->
    <h2 class="text-4xl md:text-6xl lg:text-7xl font-black uppercase leading-tight mb-8">
      {words.map((word) => (
        <span class="word-mask">
          <span class="word">{word}&nbsp;</span>
        </span>
      ))}
    </h2>

    <!-- Subtitle -->
    <p class="reveal text-lg md:text-xl text-ink-soft max-w-2xl mx-auto mb-10 leading-relaxed">
      Создаём сайты, которые приводят клиентов. Настраиваем чат-ботов и&nbsp;AI&#8209;автоматизацию, которые экономят ваше время и&nbsp;деньги.
    </p>

    <!-- CTA -->
    <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-8 py-4 bg-ink text-bg text-base font-semibold rounded-full hover:bg-ink/90 transition-all duration-300 hover:scale-105"
      >
        Получить бесплатный аудит сайта
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="#portfolio"
        class="text-ink-soft hover:text-ink text-base font-medium transition-colors duration-200"
      >
        Смотреть работы &darr;
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2">
    <span class="scroll-indicator">Листайте вниз</span>
  </div>
</section>
