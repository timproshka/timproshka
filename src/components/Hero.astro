---
import { getLangFromUrl, useTranslations } from '../i18n/useTranslations';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="hero" class="section-full relative overflow-hidden">
  <canvas id="hero-canvas" class="absolute inset-0 w-full h-full z-0" aria-hidden="true"></canvas>

  <!-- Static fallback heading: visible for reduced-motion users + provides strong LCP target -->
  <h1 id="hero-static-title" class="reduced-motion-only absolute inset-x-0 top-[20vh] md:top-[22vh] text-center text-5xl md:text-7xl font-black tracking-tight text-white z-[5] px-6">
    timproshka
  </h1>

  <div class="side-text hidden lg:block">timproshka &reg;</div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 text-center pointer-events-none">
    <!-- Spacer for the 3D text -->
    <div class="h-[28vh] md:h-[32vh]"></div>

    <p id="hero-subtitle" class="text-lg md:text-xl text-accent font-serif italic mb-6" style="opacity: 1; transform: translateY(16px); transition: transform 0.7s ease-out;">
      {t.hero.subtitle}
    </p>

    <p id="hero-desc" class="text-lg md:text-xl text-ink-soft max-w-2xl mx-auto mb-10 leading-relaxed" style="opacity: 1; transform: translateY(16px); transition: transform 0.7s ease-out 0.15s;">
      {t.hero.description}
    </p>

    <div id="hero-cta" class="flex flex-col sm:flex-row items-center justify-center gap-4 pointer-events-auto" style="opacity: 0; transform: translateY(16px); transition: opacity 0.7s ease-out 0.5s, transform 0.7s ease-out 0.5s;">
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-8 py-4 bg-accent text-white text-base font-semibold rounded-full hover:bg-accent-hover transition-all duration-300 hover:scale-105 hover:shadow-glow"
      >
        {t.hero.cta}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="#work"
        class="text-ink-soft hover:text-ink text-base font-medium transition-colors duration-200"
      >
        {t.hero.viewWork}
      </a>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10">
    <span class="scroll-indicator">{t.hero.scrollDown}</span>
  </div>
</section>

<style>
  /* Static title shows only when user prefers reduced motion OR when JS disables the canvas */
  .reduced-motion-only { display: none; }

  @media (prefers-reduced-motion: reduce) {
    #hero-canvas { display: none; }
    .reduced-motion-only { display: block; }
    #hero-subtitle,
    #hero-desc,
    #hero-cta {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  /* JS-driven fallback when Three.js init fails */
  #hero.reduced-motion #hero-canvas { display: none; }
  #hero.reduced-motion .reduced-motion-only { display: block; }
  #hero.reduced-motion #hero-subtitle,
  #hero.reduced-motion #hero-desc,
  #hero.reduced-motion #hero-cta {
    opacity: 1 !important;
    transform: none !important;
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (!canvas) throw new Error('No hero canvas');

  // === REDUCED-MOTION EARLY EXIT ===
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReducedMotion) {
    const section = document.getElementById('hero');
    section?.classList.add('reduced-motion');
    const cta = document.getElementById('hero-cta');
    if (cta) { cta.style.opacity = '1'; cta.style.transform = 'translateY(0)'; }
    const sub = document.getElementById('hero-subtitle');
    const desc = document.getElementById('hero-desc');
    if (sub) sub.style.transform = 'translateY(0)';
    if (desc) desc.style.transform = 'translateY(0)';
    throw new Error('reduced-motion: hero canvas skipped');
  }

  // === CONSTANTS ===
  const IS_MOBILE = window.matchMedia('(max-width: 767px)').matches;
  const PARTICLE_COUNT = IS_MOBILE ? 14000 : 28000;
  const TEXT = 'timproshka';
  const TEXT_WIDTH_MAX = 7.0;
  const TEXT_WIDTH_FILL = IS_MOBILE ? 0.92 : 0.88;
  const TEXT_Y_OFFSET = 0.5;

  const MORPH_DELAY = 0.3;
  const MORPH_DURATION = 2.8;

  const REPEL_RADIUS = 0.3;
  const REPEL_STRENGTH = 0.022;
  const PULL_PER_FRAME = 0.032;
  const DAMPING_PER_FRAME = 0.82;
  const MAX_VELOCITY = 0.05;
  const SUBSTEPS = IS_MOBILE ? 2 : 4;

  // === RENDERER & SCENE ===
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setClearColor(0x0A0A0F);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(60, canvas.clientWidth / canvas.clientHeight, 0.1, 100);
  camera.position.z = 3.5;

  function computeTextWidth(): number {
    const fov = 60 * Math.PI / 180;
    const aspect = canvas.clientWidth / Math.max(1, canvas.clientHeight);
    const visibleHeight = 2 * Math.tan(fov / 2) * Math.abs(camera.position.z);
    const visibleWidth = visibleHeight * aspect;
    return Math.min(TEXT_WIDTH_MAX, visibleWidth * TEXT_WIDTH_FILL);
  }

  function sampleTextPositions(text: string, count: number, textWidth: number): { positions: Float32Array; textHeight: number } {
    const RES_W = 2400;
    const RES_H = 500;
    const off = document.createElement('canvas');
    off.width = RES_W;
    off.height = RES_H;
    const ctx = off.getContext('2d')!;

    ctx.fillStyle = '#000';
    ctx.fillRect(0, 0, RES_W, RES_H);
    ctx.fillStyle = '#fff';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';

    const padding = 40;
    let fontSize = RES_H * 0.75;
    ctx.font = `900 ${fontSize}px Inter, system-ui, sans-serif`;
    let metrics = ctx.measureText(text);
    while (metrics.width > RES_W - padding * 2 && fontSize > 20) {
      fontSize -= 4;
      ctx.font = `900 ${fontSize}px Inter, system-ui, sans-serif`;
      metrics = ctx.measureText(text);
    }
    ctx.fillText(text, RES_W / 2, RES_H / 2);

    const imageData = ctx.getImageData(0, 0, RES_W, RES_H);
    const pixels: [number, number][] = [];
    for (let y = 0; y < RES_H; y++) {
      for (let x = 0; x < RES_W; x++) {
        const i = (y * RES_W + x) * 4;
        if (imageData.data[i] > 128) {
          pixels.push([x, y]);
        }
      }
    }

    let minX = RES_W, maxX = 0, minY = RES_H, maxY = 0;
    for (const [x, y] of pixels) {
      if (x < minX) minX = x;
      if (x > maxX) maxX = x;
      if (y < minY) minY = y;
      if (y > maxY) maxY = y;
    }
    const textW = maxX - minX;
    const textH = maxY - minY;

    const worldScale = textWidth / textW;
    const worldHeight = textH * worldScale;

    const positions = new Float32Array(count * 3);
    for (let i = 0; i < count; i++) {
      const px = pixels[Math.floor(Math.random() * pixels.length)];
      if (!px) continue;
      const cx = minX + textW / 2;
      const cy = minY + textH / 2;
      positions[i * 3]     = (px[0] - cx) * worldScale;
      positions[i * 3 + 1] = -(px[1] - cy) * worldScale + TEXT_Y_OFFSET;
      positions[i * 3 + 2] = (Math.random() - 0.5) * 0.04;
    }

    return { positions, textHeight: worldHeight };
  }

  const { positions: targetPositions } = sampleTextPositions(TEXT, PARTICLE_COUNT, computeTextWidth());

  const startPositions = new Float32Array(PARTICLE_COUNT * 3);
  for (let i = 0; i < PARTICLE_COUNT; i++) {
    const theta = Math.random() * Math.PI * 2;
    const phi = Math.acos(2 * Math.random() - 1);
    const r = 5 + Math.random() * 8;
    startPositions[i * 3]     = r * Math.sin(phi) * Math.cos(theta);
    startPositions[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
    startPositions[i * 3 + 2] = (Math.random() - 0.5) * 3;
  }

  const currentPositions = new Float32Array(startPositions);
  const velocities = new Float32Array(PARTICLE_COUNT * 3);

  const sizes = new Float32Array(PARTICLE_COUNT);
  const alphas = new Float32Array(PARTICLE_COUNT);
  const morphDelays = new Float32Array(PARTICLE_COUNT);
  for (let i = 0; i < PARTICLE_COUNT; i++) {
    sizes[i] = IS_MOBILE
      ? Math.random() * 1.5 + 2.0
      : Math.random() * 2 + 2.5;
    alphas[i] = Math.random() * 0.15 + 0.85;
    morphDelays[i] = Math.random() * 0.6;
  }

  const geometry = new THREE.BufferGeometry();
  geometry.setAttribute('position', new THREE.BufferAttribute(currentPositions, 3));
  geometry.setAttribute('aSize', new THREE.BufferAttribute(sizes, 1));
  geometry.setAttribute('aAlpha', new THREE.BufferAttribute(alphas, 1));

  const material = new THREE.ShaderMaterial({
    uniforms: {
      uTime: { value: 0 },
      uPixelRatio: { value: renderer.getPixelRatio() },
    },
    vertexShader: `
      attribute float aSize;
      attribute float aAlpha;
      uniform float uTime;
      uniform float uPixelRatio;
      varying float vAlpha;

      void main() {
        vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
        gl_PointSize = aSize * uPixelRatio * (1.0 / -mvPosition.z);
        gl_Position = projectionMatrix * mvPosition;
        vAlpha = aAlpha;
      }
    `,
    fragmentShader: `
      varying float vAlpha;

      void main() {
        float d = length(gl_PointCoord - 0.5);
        if (d > 0.5) discard;

        float strength = 1.0 - smoothstep(0.35, 0.5, d);

        vec3 purple = vec3(0.486, 0.361, 0.988);
        vec3 lavender = vec3(0.85, 0.75, 1.0);
        vec3 white = vec3(1.0);
        vec3 color = mix(purple, lavender, strength);
        color = mix(color, white, pow(strength, 2.0));

        gl_FragColor = vec4(color, strength * vAlpha);
      }
    `,
    transparent: true,
    depthWrite: false,
    blending: THREE.NormalBlending,
  });

  const points = new THREE.Points(geometry, material);
  scene.add(points);

  const mouseNDC = new THREE.Vector2(10, 10);
  const mouseWorldRaw = new THREE.Vector3(100, 100, 0);
  const mouseWorldPrev = new THREE.Vector3(100, 100, 0);
  const mousePath: THREE.Vector3[] = [];
  const raycaster = new THREE.Raycaster();
  const intersectPlane = new THREE.Plane(new THREE.Vector3(0, 0, 1), 0);
  let mouseActive = false;

  function ndcToWorld(ndcX: number, ndcY: number, out: THREE.Vector3) {
    const tmpNDC = new THREE.Vector2(ndcX, ndcY);
    raycaster.setFromCamera(tmpNDC, camera);
    raycaster.ray.intersectPlane(intersectPlane, out);
  }

  function clearPointer() {
    mouseNDC.set(10, 10);
    mouseActive = false;
    mousePath.length = 0;
  }

  let touchStartX = 0;
  let touchStartY = 0;
  let touchMode: 'undecided' | 'scroll' | 'physics' = 'undecided';
  let ignorePointer = false;

  canvas.addEventListener('touchstart', (e) => {
    const t = e.touches[0];
    touchStartX = t.clientX;
    touchStartY = t.clientY;
    touchMode = 'undecided';
    ignorePointer = false;
  }, { passive: true });

  canvas.addEventListener('touchmove', (e) => {
    const t = e.touches[0];
    const dx = t.clientX - touchStartX;
    const dy = t.clientY - touchStartY;
    const adx = Math.abs(dx);
    const ady = Math.abs(dy);

    if (touchMode === 'undecided' && (adx > 8 || ady > 8)) {
      if (ady > adx * 1.3) {
        touchMode = 'scroll';
        ignorePointer = true;
        clearPointer();
      } else {
        touchMode = 'physics';
      }
    }

    if (touchMode === 'physics') {
      e.preventDefault();
    }
  }, { passive: false });

  window.addEventListener('pointermove', (e) => {
    if (ignorePointer) return;

    const rect = canvas.getBoundingClientRect();
    mouseNDC.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
    mouseNDC.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;

    const pt = new THREE.Vector3();
    ndcToWorld(mouseNDC.x, mouseNDC.y, pt);

    if (!mouseActive) {
      mouseWorldRaw.copy(pt);
      mouseWorldPrev.copy(pt);
      mousePath.length = 0;
      mousePath.push(pt.clone());
      mouseActive = true;
    } else {
      mousePath.push(pt.clone());
      mouseWorldRaw.copy(pt);
    }
  });

  function endTouch() {
    touchMode = 'undecided';
    ignorePointer = false;
    clearPointer();
  }

  window.addEventListener('mouseleave', clearPointer);
  window.addEventListener('pointerup', clearPointer);
  window.addEventListener('pointercancel', clearPointer);
  window.addEventListener('touchend', endTouch, { passive: true });
  window.addEventListener('touchcancel', endTouch, { passive: true });
  window.addEventListener('scroll', clearPointer, { passive: true });

  let lastTextWidth = computeTextWidth();
  let resampleTimer: number | null = null;

  function resize() {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    const pr = renderer.getPixelRatio();
    if (canvas.width !== w * pr || canvas.height !== h * pr) {
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();

      const newTextWidth = computeTextWidth();
      if (Math.abs(newTextWidth - lastTextWidth) > 0.05) {
        lastTextWidth = newTextWidth;
        if (resampleTimer !== null) clearTimeout(resampleTimer);
        resampleTimer = window.setTimeout(() => {
          const { positions } = sampleTextPositions(TEXT, PARTICLE_COUNT, newTextWidth);
          targetPositions.set(positions);
          resampleTimer = null;
        }, 150);
      }
    }
  }

  const clock = new THREE.Clock();
  let running = true;
  let morphComplete = false;
  let textShown = false;
  let ctaShown = false;

  const MIN_SEG_SQ = 0.0004;
  function buildFrameSegments(): Float32Array {
    if (!mouseActive) return new Float32Array(0);

    const pts: number[] = [];
    pts.push(mouseWorldPrev.x, mouseWorldPrev.y);
    for (const p of mousePath) {
      const lastX = pts[pts.length - 2];
      const lastY = pts[pts.length - 1];
      const dx = p.x - lastX;
      const dy = p.y - lastY;
      if (dx * dx + dy * dy > MIN_SEG_SQ) {
        pts.push(p.x, p.y);
      }
    }
    {
      const lastX = pts[pts.length - 2];
      const lastY = pts[pts.length - 1];
      const dx = mouseWorldRaw.x - lastX;
      const dy = mouseWorldRaw.y - lastY;
      if (dx * dx + dy * dy > MIN_SEG_SQ) {
        pts.push(mouseWorldRaw.x, mouseWorldRaw.y);
      }
    }
    return new Float32Array(pts);
  }

  const _tmpResult = { dist: 0, nx: 0, ny: 0 };
  function distToPolyline(px: number, py: number, poly: Float32Array): { dist: number; nx: number; ny: number } {
    let bestDist = Infinity;
    let bestNx = 0, bestNy = 0;
    const n = poly.length;
    if (n < 2) {
      _tmpResult.dist = Infinity;
      _tmpResult.nx = 0;
      _tmpResult.ny = 0;
      return _tmpResult;
    }
    if (n === 2) {
      const dx = px - poly[0];
      const dy = py - poly[1];
      const d = Math.sqrt(dx * dx + dy * dy);
      _tmpResult.dist = d;
      if (d > 1e-6) {
        _tmpResult.nx = dx / d;
        _tmpResult.ny = dy / d;
      } else {
        _tmpResult.nx = 0;
        _tmpResult.ny = 0;
      }
      return _tmpResult;
    }
    for (let i = 0; i < n - 2; i += 2) {
      const ax = poly[i];
      const ay = poly[i + 1];
      const bx = poly[i + 2];
      const by = poly[i + 3];
      const segDx = bx - ax;
      const segDy = by - ay;
      const segLenSq = segDx * segDx + segDy * segDy;
      let closestX: number, closestY: number;
      if (segLenSq < 1e-8) {
        closestX = ax;
        closestY = ay;
      } else {
        const t = Math.max(0, Math.min(1, ((px - ax) * segDx + (py - ay) * segDy) / segLenSq));
        closestX = ax + t * segDx;
        closestY = ay + t * segDy;
      }
      const dx = px - closestX;
      const dy = py - closestY;
      const d = Math.sqrt(dx * dx + dy * dy);
      if (d < bestDist) {
        bestDist = d;
        if (d > 1e-6) {
          bestNx = dx / d;
          bestNy = dy / d;
        } else {
          bestNx = 0;
          bestNy = 0;
        }
      }
    }
    _tmpResult.dist = bestDist;
    _tmpResult.nx = bestNx;
    _tmpResult.ny = bestNy;
    return _tmpResult;
  }

  function animate() {
    if (!running) return;
    requestAnimationFrame(animate);

    const elapsed = clock.getElapsedTime();
    resize();

    const pos = geometry.attributes.position.array as Float32Array;

    if (!morphComplete) {
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        const i3 = i * 3;
        const localTime = Math.max(0, elapsed - MORPH_DELAY - morphDelays[i]);
        const t = Math.min(1, localTime / MORPH_DURATION);
        const ease = 1 - Math.pow(1 - t, 3);

        pos[i3]     = startPositions[i3]     + (targetPositions[i3]     - startPositions[i3])     * ease;
        pos[i3 + 1] = startPositions[i3 + 1] + (targetPositions[i3 + 1] - startPositions[i3 + 1]) * ease;
        pos[i3 + 2] = startPositions[i3 + 2] + (targetPositions[i3 + 2] - startPositions[i3 + 2]) * ease;
      }

      if (elapsed > MORPH_DELAY + MORPH_DURATION + 0.6) {
        morphComplete = true;
        mouseWorldPrev.copy(mouseWorldRaw);
        mousePath.length = 0;
      }

      if (!textShown && elapsed > 0.15) {
        const sub = document.getElementById('hero-subtitle');
        const desc = document.getElementById('hero-desc');
        if (sub) sub.style.transform = 'translateY(0)';
        if (desc) desc.style.transform = 'translateY(0)';
        textShown = true;
      }
    } else {
      const poly = buildFrameSegments();
      const hasPoly = mouseActive && poly.length >= 2;

      const repelStrengthPerSubstep = REPEL_STRENGTH / SUBSTEPS;
      const invSub = 1 / SUBSTEPS;
      const dampingPerSubstep = Math.pow(DAMPING_PER_FRAME, invSub);
      const pullPerSubstep = 1 - Math.pow(1 - PULL_PER_FRAME, invSub);
      const maxVel = MAX_VELOCITY;
      const maxVelSq = maxVel * maxVel;

      for (let step = 0; step < SUBSTEPS; step++) {
        for (let i = 0; i < PARTICLE_COUNT; i++) {
          const i3 = i * 3;
          const px = pos[i3];
          const py = pos[i3 + 1];
          const pz = pos[i3 + 2];

          if (hasPoly) {
            const r = distToPolyline(px, py, poly);
            if (r.dist < REPEL_RADIUS) {
              const n = 1 - r.dist / REPEL_RADIUS;
              const falloff = n * n * (3 - 2 * n);
              const force = falloff * repelStrengthPerSubstep;
              velocities[i3]     += r.nx * force;
              velocities[i3 + 1] += r.ny * force;
            }
          }

          velocities[i3]     *= dampingPerSubstep;
          velocities[i3 + 1] *= dampingPerSubstep;
          velocities[i3 + 2] *= dampingPerSubstep;

          const vx = velocities[i3];
          const vy = velocities[i3 + 1];
          const vMagSq = vx * vx + vy * vy;
          if (vMagSq > maxVelSq) {
            const scale = maxVel / Math.sqrt(vMagSq);
            velocities[i3]     *= scale;
            velocities[i3 + 1] *= scale;
          }

          const nextX = px + velocities[i3]     * invSub;
          const nextY = py + velocities[i3 + 1] * invSub;
          const nextZ = pz + velocities[i3 + 2] * invSub;

          pos[i3]     = nextX + (targetPositions[i3]     - nextX) * pullPerSubstep;
          pos[i3 + 1] = nextY + (targetPositions[i3 + 1] - nextY) * pullPerSubstep;
          pos[i3 + 2] = nextZ + (targetPositions[i3 + 2] - nextZ) * pullPerSubstep;
        }
      }

      mouseWorldPrev.copy(mouseWorldRaw);
      mousePath.length = 0;

      if (!ctaShown) {
        const cta = document.getElementById('hero-cta');
        if (cta) { cta.style.opacity = '1'; cta.style.transform = 'translateY(0)'; }
        ctaShown = true;
      }
    }

    geometry.attributes.position.needsUpdate = true;
    material.uniforms.uTime.value = elapsed;

    renderer.render(scene, camera);
  }

  const observer = new IntersectionObserver(([entry]) => {
    const wasRunning = running;
    running = entry.isIntersecting;
    if (running && !wasRunning) {
      animate();
    }
  }, { threshold: 0.05 });
  observer.observe(canvas);

  if ((document as any).fonts?.ready) {
    (document as any).fonts.ready.then(() => {
      const { positions: newPositions } = sampleTextPositions(TEXT, PARTICLE_COUNT, computeTextWidth());
      targetPositions.set(newPositions);
      animate();
    });
  } else {
    animate();
  }
</script>
