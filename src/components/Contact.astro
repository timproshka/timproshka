---

---

<section id="contact" class="section-full">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="section-number reveal">Начнём</span>
      <h2 class="text-4xl md:text-6xl font-black uppercase mt-3 reveal">
        Готовы получать<br />клиентов онлайн?
      </h2>
      <p class="text-ink-soft text-lg mt-4 reveal max-w-xl mx-auto">
        Оставьте заявку — проведём бесплатный аудит вашего сайта и&nbsp;покажем, что можно улучшить.
      </p>
      <p class="text-sm font-semibold text-ink mt-4 reveal">
        Берём максимум 3 проекта в месяц. Сейчас свободно 2&nbsp;места.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Form -->
      <form
        id="contact-form"
        class="space-y-6 reveal-up"
      >
        <div>
          <label for="name" class="block text-sm font-medium text-ink-soft mb-2">Имя</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 bg-transparent border-b-2 border-border focus:border-ink outline-none transition-colors text-ink placeholder-ink-soft/50"
            placeholder="Как вас зовут?"
          />
        </div>

        <div>
          <label for="telegram" class="block text-sm font-medium text-ink-soft mb-2">Telegram / Телефон</label>
          <input
            type="text"
            id="telegram"
            name="telegram"
            required
            class="w-full px-4 py-3 bg-transparent border-b-2 border-border focus:border-ink outline-none transition-colors text-ink placeholder-ink-soft/50"
            placeholder="@username или +7..."
          />
        </div>

        <div>
          <label for="task" class="block text-sm font-medium text-ink-soft mb-2">Задача</label>
          <textarea
            id="task"
            name="task"
            rows="4"
            class="w-full px-4 py-3 bg-transparent border-b-2 border-border focus:border-ink outline-none transition-colors text-ink placeholder-ink-soft/50 resize-none"
            placeholder="Опишите вашу задачу..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="inline-flex items-center gap-2 px-8 py-4 bg-ink text-bg text-base font-semibold rounded-full hover:bg-ink/90 transition-all duration-300 hover:scale-105 w-full md:w-auto justify-center"
        >
          Отправить
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>
      </form>

      <!-- Direct contact -->
      <div class="reveal-up flex flex-col justify-center space-y-8">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-ink-soft block mb-3">Или напишите напрямую</span>
          <a
            href="https://t.me/timproshka"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 text-2xl font-bold hover:text-ink-soft transition-colors group"
          >
            <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
              <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
            @timproshka
            <svg class="w-5 h-5 text-ink-soft group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <div class="text-ink-soft text-sm leading-relaxed">
          <p>Отвечаю в течение дня.</p>
          <p>Пермь, Россия</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const name = formData.get('name');
    const telegram = formData.get('telegram');
    const task = formData.get('task');

    // Open Telegram with pre-filled message
    const message = encodeURIComponent(
      `\u041d\u043e\u0432\u0430\u044f \u0437\u0430\u044f\u0432\u043a\u0430 \u0441 \u0441\u0430\u0439\u0442\u0430 timproshka:\n\n\u0418\u043c\u044f: ${name}\n\u041a\u043e\u043d\u0442\u0430\u043a\u0442: ${telegram}\n\u0417\u0430\u0434\u0430\u0447\u0430: ${task}`
    );
    window.open(`https://t.me/timproshka?text=${message}`, '_blank');

    // Show success
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (btn) {
      btn.textContent = '\u041e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u043e!';
      btn.disabled = true;
      setTimeout(() => {
        btn.textContent = '\u041e\u0442\u043f\u0440\u0430\u0432\u0438\u0442\u044c';
        btn.disabled = false;
        form.reset();
      }, 3000);
    }
  });
</script>
