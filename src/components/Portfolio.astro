---
const projects = [
  {
    title: 'Nuzhnyi Adres',
    desc: 'Real estate agency website with smooth animations. Loads in 1.2s, fully responsive.',
    result: 'Built from scratch in 10 days',
    tags: ['Website', 'Animations'],
    image: '/projects/nuzhnyi-adres.jpg',
    url: 'https://nuzhnyi-adres.ru',
    live: true,
  },
  {
    title: 'Onica',
    desc: 'Corporate website for an accounting firm. Lead capture forms, service pages, SEO optimization.',
    result: 'Leads from the site within the first week',
    tags: ['Website', 'Forms'],
    image: '/projects/onica.jpg',
    url: 'https://onica59.ru',
    live: true,
  },
  {
    title: 'AI Clinic Assistant',
    desc: 'Telegram bot for appointment booking. Connected to doctor calendars and client database.',
    result: 'Books clients 24/7 without admin involvement',
    tags: ['Chatbot', 'Telegram'],
    image: null,
    url: null,
    live: false,
  },
  {
    title: 'Report Automation',
    desc: 'Automated data collection from multiple sources with weekly report delivery to management.',
    result: 'Saves 8 hours per week',
    tags: ['Automation', 'Reports'],
    image: null,
    url: null,
    live: false,
  },
];
---

<section id="work" class="section-full">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-20 reveal">
      <span class="section-number">Portfolio</span>
      <h2 class="text-4xl md:text-5xl font-black uppercase mt-3">
        Selected <span class="font-serif italic font-normal text-accent">work</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {projects.map((project) => (
        <a
          href={project.url || '#work'}
          target={project.url ? '_blank' : undefined}
          rel={project.url ? 'noopener noreferrer' : undefined}
          class:list={[
            'card overflow-hidden reveal-scale group block',
            project.url && 'cursor-pointer',
            !project.url && 'pointer-events-none'
          ]}
        >
          <div class="h-48 md:h-64 flex items-center justify-center relative overflow-hidden bg-surface">
            {project.image ? (
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            ) : (
              <div class="text-center px-8">
                <p class="text-3xl md:text-4xl font-black text-ink/10 uppercase leading-tight">{project.title}</p>
              </div>
            )}
            {project.live && (
              <span class="absolute top-4 right-4 badge-available text-[10px]">
                Live
              </span>
            )}
            {project.url && (
              <div class="absolute inset-0 bg-accent/0 group-hover:bg-accent/10 transition-colors duration-300 flex items-center justify-center">
                <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-sm font-semibold text-ink bg-surface/80 backdrop-blur-sm px-4 py-2 rounded-full">
                  View site &rarr;
                </span>
              </div>
            )}
          </div>

          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">{project.title}</h3>
            <p class="text-ink-soft text-sm leading-relaxed mb-3">{project.desc}</p>
            {project.result && (
              <p class="text-sm font-semibold text-accent/80 flex items-center gap-1.5 mb-3">
                <svg class="w-4 h-4 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {project.result}
              </p>
            )}
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="px-2.5 py-0.5 text-[11px] font-mono font-medium uppercase tracking-wider border border-surface-border rounded-full text-ink-muted">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
