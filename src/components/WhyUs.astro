---
const reasons = [
  {
    title: 'Быстро',
    desc: 'Ваш сайт готов за 14 дней, а не за 3 месяца. Каждые 3 дня вы видите прогресс.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>',
  },
  {
    title: 'Напрямую',
    desc: 'Общаетесь с тем, кто делает ваш проект. Никаких менеджеров и посредников.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>',
  },
  {
    title: 'Современно',
    desc: 'Используем AI и свежие технологии. То, что крупные агентства только начинают внедрять.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>',
  },
  {
    title: 'С гарантией',
    desc: 'Не понравился результат — вернём деньги в течение 14 дней. Без вопросов.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>',
  },
];
---

<section id="why" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 reveal">
      <span class="section-number">Почему мы</span>
      <h2 class="text-4xl md:text-5xl font-black uppercase mt-3">
        Чем мы отличаемся
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6" data-stagger>
      {reasons.map((r) => (
        <div class="card p-6 text-center">
          <div class="w-14 h-14 mx-auto rounded-full bg-ink/5 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={r.icon} />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">{r.title}</h3>
          <p class="text-ink-soft text-sm leading-relaxed">{r.desc}</p>
        </div>
      ))}
    </div>

    <!-- Guarantee banner -->
    <div class="mt-16 reveal">
      <div class="guarantee-card border-2 border-ink rounded-card p-8 md:p-10 text-center max-w-3xl mx-auto relative overflow-hidden">
        <!-- Animated shimmer -->
        <div class="guarantee-shimmer"></div>
        <div class="relative z-10">
          <div class="flex items-center justify-center gap-3 mb-4">
            <div class="guarantee-icon w-12 h-12 rounded-full bg-ink flex items-center justify-center">
              <svg class="w-6 h-6 text-bg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <h3 class="text-2xl md:text-3xl font-black uppercase">Гарантия возврата</h3>
          </div>
          <p class="text-ink-soft text-lg leading-relaxed">
            Если результат вас не устроит — вернём полную оплату в течение 14 дней после сдачи проекта. Без вопросов и&nbsp;лишних условий. Мы уверены в&nbsp;своей работе.
          </p>
        </div>
      </div>
    </div>

  </div>
</section>
