  {
    num: '04',
    title: '\u0417\u0430\u043f\u0443\u0441\u043a',
    desc: '\u0422\u0435\u0441\u0442\u0438\u0440\u0443\u0435\u043c, \u0440\u0430\u0437\u043c\u0435\u0449\u0430\u0435\u043c \u0432 \u0438\u043d\u0442\u0435\u0440\u043d\u0435\u0442\u0435, \u043d\u0430\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0435\u043c \u0430\u043d\u0430\u043b\u0438\u0442\u0438\u043a\u0443. \u041f\u043e\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u043c \u043f\u043e\u0441\u043b\u0435 \u0437\u0430\u043f\u0443\u0441\u043a\u0430.',
