---
const steps = [
  {
    num: '01',
    title: 'Знакомство',
    desc: 'Обсуждаем задачу, определяем цели и пожелания. Анализируем конкурентов и ваших клиентов.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>',
  },
  {
    num: '02',
    title: 'Дизайн',
    desc: 'Создаём макет и внешний вид сайта. Утверждаем оформление перед разработкой.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/>',
  },
  {
    num: '03',
    title: 'Разработка',
    desc: 'Пишем код, наполняем сайт содержимым. Ежедневные обновления и промежуточный просмотр.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>',
  },
  {
    num: '04',
    title: 'Запуск',
    desc: 'Тестируем, размещаем в интернете, настраиваем аналитику. Поддерживаем после запуска.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>',
  },
];
---

<section id="process" class="py-20 md:py-0">
  <!-- Mobile: vertical cards -->
  <div class="md:hidden px-6">
    <div class="mb-12">
      <span class="section-number reveal">Процесс</span>
      <h2 class="text-4xl font-black uppercase mt-3 reveal">Как мы работаем</h2>
    </div>
    <div class="space-y-6" data-stagger>
      {steps.map((step) => (
        <div class="card p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-4xl font-black text-ink/10">{step.num}</span>
            <svg class="w-5 h-5 text-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={step.icon} />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">{step.title}</h3>
          <p class="text-ink-soft leading-relaxed text-sm">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Desktop: horizontal scroll pin -->
  <div class="hidden md:block relative overflow-hidden" style="min-height: 100vh;">
    <div class="flex items-center" style="min-height: 100vh;">
      <div class="horizontal-scroll flex items-center pl-20">
        <div class="flex-shrink-0 w-[40vw] pr-16">
          <span class="section-number reveal">Процесс</span>
          <h2 class="text-5xl font-black uppercase mt-3 reveal">
            Как мы<br />работаем
          </h2>
        </div>

        {steps.map((step) => (
          <div class="flex-shrink-0 w-[35vw] pr-8">
            <div class="card p-10 h-full">
              <div class="flex items-center gap-4 mb-6">
                <span class="text-5xl font-black text-ink/10">{step.num}</span>
                <svg class="w-6 h-6 text-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={step.icon} />
                </svg>
              </div>
              <h3 class="text-2xl font-bold mb-3">{step.title}</h3>
              <p class="text-ink-soft leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}

        <div class="flex-shrink-0 w-[10vw]"></div>
      </div>
    </div>
  </div>
</section>
