---

<section id="process" class="relative overflow-hidden" style="min-height: 100vh;">
  <div class="flex items-center" style="min-height: 100vh;">
    <div class="horizontal-scroll flex items-center pl-6 md:pl-20">
      <!-- Intro card -->
      <div class="flex-shrink-0 w-[90vw] md:w-[40vw] pr-8 md:pr-16">
        <span class="section-number reveal">Процесс</span>
        <h2 class="text-4xl md:text-5xl font-black uppercase mt-3 reveal">
          Как мы<br />работаем
        </h2>
      </div>

      <!-- Steps -->
      {steps.map((step) => (
        <div class="flex-shrink-0 w-[85vw] md:w-[35vw] pr-8">
          <div class="card p-8 md:p-10 h-full">
            <div class="flex items-center gap-4 mb-6">
              <span class="text-5xl font-black text-ink/10">{step.num}</span>
              <svg class="w-6 h-6 text-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={step.icon} />
              </svg>
            </div>
            <h3 class="text-2xl font-bold mb-3">{step.title}</h3>
            <p class="text-ink-soft leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}

      <!-- Spacer for end -->
      <div class="flex-shrink-0 w-[10vw]"></div>
    </div>
  </div>
</section>
