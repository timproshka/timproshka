---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'timproshka — Web Developer & AI Automation Engineer',
  description = 'I build websites that convert and AI systems that save time. Web development, chatbots, and automation. Available for freelance projects.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: Inter + Instrument Serif + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@1&family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="noise-overlay">
    <slot />

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger);

      // ===== LENIS SMOOTH SCROLL =====
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        touchMultiplier: 2,
      });

      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time: number) => {
        lenis.raf(time * 1000);
      });
      gsap.ticker.lagSmoothing(0);

      // ===== JS-READY FLAG =====
      document.documentElement.classList.add('js-ready');

      const fallbackTimer = setTimeout(() => {
        document.documentElement.classList.remove('js-ready');
      }, 3000);
      lenis.on('scroll', () => clearTimeout(fallbackTimer));

      // ===== INTRO ANIMATION =====
      const introOverlay = document.querySelector('#intro-overlay') as HTMLElement;
      const introChars = document.querySelectorAll('.intro-char');
      const header = document.querySelector('#site-header') as HTMLElement;

      if (introOverlay && introChars.length > 0) {
        const introTl = gsap.timeline({
          onComplete: () => {
            introOverlay.style.pointerEvents = 'none';
            if (header) header.style.opacity = '1';
          },
        });

        introTl
          .set(introChars, { opacity: 0, y: 30 })
          .to(introChars, {
            opacity: 1,
            y: 0,
            duration: 0.6,
            stagger: 0.08,
            ease: 'power3.out',
          })
          .to(introChars, {
            scale: 1.1,
            duration: 0.4,
            ease: 'power2.inOut',
            delay: 0.3,
          })
          .to(introOverlay, {
            opacity: 0,
            duration: 0.8,
            ease: 'power2.inOut',
          });
      }

      // ===== SCROLL REVEAL =====
      const reveals = document.querySelectorAll('.reveal');
      reveals.forEach((el) => {
        gsap.set(el, { opacity: 0, y: 40 });
        gsap.to(el, {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        });
      });

      const revealUps = document.querySelectorAll('.reveal-up');
      revealUps.forEach((el) => {
        gsap.set(el, { opacity: 0, y: 60 });
        gsap.to(el, {
          opacity: 1,
          y: 0,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        });
      });

      const revealScales = document.querySelectorAll('.reveal-scale');
      revealScales.forEach((el) => {
        gsap.set(el, { opacity: 0, scale: 0.85 });
        gsap.to(el, {
          opacity: 1,
          scale: 1,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        });
      });

      const staggerParents = document.querySelectorAll('[data-stagger]');
      staggerParents.forEach((parent) => {
        const children = parent.children;
        gsap.set(children, { opacity: 0, y: 24 });
        gsap.to(children, {
          opacity: 1,
          y: 0,
          duration: 0.6,
          stagger: 0.08,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: parent,
            start: 'top 80%',
            toggleActions: 'play none none none',
          },
        });
      });

      // ===== HERO TEXT WORD REVEAL =====
      const heroWords = document.querySelectorAll('.word-mask .word');
      if (heroWords.length > 0) {
        gsap.set(heroWords, { y: '100%' });
        gsap.to(heroWords, {
          y: 0,
          duration: 0.8,
          stagger: 0.06,
          ease: 'power3.out',
          delay: 2.2,
        });
      }

      // ===== SERVICES: clipPath reveal =====
      const sectionNumbers = document.querySelectorAll('.section-number-reveal');
      sectionNumbers.forEach((el) => {
        gsap.set(el, { clipPath: 'inset(0 100% 0 0)' });
        gsap.to(el, {
          clipPath: 'inset(0 0% 0 0)',
          duration: 0.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 80%',
            toggleActions: 'play none none none',
          },
        });
      });

      // ===== PROCESS: Horizontal scroll pin =====
      const processSection = document.querySelector('#process');
      const processTrack = document.querySelector('.horizontal-scroll');

      if (processSection && processTrack) {
        const totalWidth = (processTrack as HTMLElement).scrollWidth - window.innerWidth;

        gsap.to(processTrack, {
          x: -totalWidth,
          ease: 'none',
          scrollTrigger: {
            trigger: processSection,
            start: 'top top',
            end: `+=${totalWidth}`,
            pin: true,
            scrub: 1,
            anticipatePin: 1,
          },
        });
      }

      // ===== HEADER: Show on scroll =====
      if (header) {
        header.style.opacity = '0';
        header.style.transition = 'opacity 0.3s ease';
      }
    </script>
  </body>
</html>
