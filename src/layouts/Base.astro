---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'timproshka — \u0412\u0435\u0431-\u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430 \u0438 AI-\u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u044f',
  description = '\u0421\u043e\u0437\u0434\u0430\u0451\u043c \u0446\u0438\u0444\u0440\u043e\u0432\u044b\u0435 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u044b \u0434\u043b\u044f \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e\u0433\u043e \u0431\u0438\u0437\u043d\u0435\u0441\u0430. \u0420\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430 \u0441\u0430\u0439\u0442\u043e\u0432, \u0447\u0430\u0442-\u0431\u043e\u0442\u044b, AI-\u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u044f. \u041f\u0435\u0440\u043c\u044c.',
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- OG Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Font: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />

    <!-- Scripts loaded at the end for performance -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger);

      // ===== LENIS SMOOTH SCROLL =====
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        touchMultiplier: 2,
      });

      // Sync Lenis with GSAP ticker
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time: number) => {
        lenis.raf(time * 1000);
      });
      gsap.ticker.lagSmoothing(0);

      // ===== ANIMATION SAFETY: Add .js-ready only after GSAP init =====
      document.documentElement.classList.add('js-ready');

      // Fallback: if scroll doesn't fire within 3s, remove .js-ready
      const fallbackTimer = setTimeout(() => {
        document.documentElement.classList.remove('js-ready');
      }, 3000);
      lenis.on('scroll', () => clearTimeout(fallbackTimer));

      // ===== INTRO ANIMATION =====
      const introOverlay = document.querySelector('#intro-overlay') as HTMLElement;
      const introChars = document.querySelectorAll('.intro-char');
      const header = document.querySelector('#site-header') as HTMLElement;

      if (introOverlay && introChars.length > 0) {
        const introTl = gsap.timeline({
          onComplete: () => {
            introOverlay.style.pointerEvents = 'none';
            if (header) header.style.opacity = '1';
          },
        });

        introTl
          .set(introChars, { opacity: 0, y: 30 })
          .to(introChars, {
            opacity: 1,
            y: 0,
            duration: 0.6,
            stagger: 0.08,
            ease: 'power3.out',
          })
          .to(introChars, {
            scale: 1.1,
            duration: 0.4,
            ease: 'power2.inOut',
            delay: 0.3,
          })
          .to(introOverlay, {
            opacity: 0,
            duration: 0.8,
            ease: 'power2.inOut',
          });
      }

      // ===== SCROLL REVEAL ANIMATIONS =====
      // Reveal elements on scroll
      const reveals = document.querySelectorAll('.reveal');
      reveals.forEach((el) => {
        gsap.set(el, { opacity: 0, y: 40 });
        gsap.to(el, {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        });
      });

      // Reveal-up (bigger offset)
      const revealUps = document.querySelectorAll('.reveal-up');
      revealUps.forEach((el) => {
        gsap.set(el, { opacity: 0, y: 60 });
        gsap.to(el, {
          opacity: 1,
          y: 0,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        });
      });

      // Reveal-scale (portfolio cards)
      const revealScales = document.querySelectorAll('.reveal-scale');
      revealScales.forEach((el) => {
        gsap.set(el, { opacity: 0, scale: 0.85 });
        gsap.to(el, {
          opacity: 1,
          scale: 1,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        });
      });

      // Stagger children
      const staggerParents = document.querySelectorAll('[data-stagger]');
      staggerParents.forEach((parent) => {
        const children = parent.children;
        gsap.set(children, { opacity: 0, y: 24 });
        gsap.to(children, {
          opacity: 1,
          y: 0,
          duration: 0.6,
          stagger: 0.08,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: parent,
            start: 'top 80%',
            toggleActions: 'play none none none',
          },
        });
      });

      // ===== HERO TEXT WORD REVEAL =====
      const heroWords = document.querySelectorAll('.word-mask .word');
      if (heroWords.length > 0) {
        gsap.set(heroWords, { y: '100%' });
        gsap.to(heroWords, {
          y: 0,
          duration: 0.8,
          stagger: 0.1,
          ease: 'power3.out',
          delay: 2.2, // After intro
        });
      }

      // ===== SERVICES: clipPath reveal for numbers =====
      const sectionNumbers = document.querySelectorAll('.section-number-reveal');
      sectionNumbers.forEach((el) => {
        gsap.set(el, { clipPath: 'inset(0 100% 0 0)' });
        gsap.to(el, {
          clipPath: 'inset(0 0% 0 0)',
          duration: 0.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 80%',
            toggleActions: 'play none none none',
          },
        });
      });

      // ===== PORTFOLIO: Parallax images =====
      const parallaxImages = document.querySelectorAll('[data-parallax]');
      parallaxImages.forEach((img) => {
        gsap.to(img, {
          y: -60,
          ease: 'none',
          scrollTrigger: {
            trigger: img.closest('.card') || img,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1,
          },
        });
      });

      // ===== PROCESS: Horizontal scroll pin =====
      const processSection = document.querySelector('#process');
      const processTrack = document.querySelector('.horizontal-scroll');

      if (processSection && processTrack) {
        const totalWidth = (processTrack as HTMLElement).scrollWidth - window.innerWidth;

        gsap.to(processTrack, {
          x: -totalWidth,
          ease: 'none',
          scrollTrigger: {
            trigger: processSection,
            start: 'top top',
            end: `+=${totalWidth}`,
            pin: true,
            scrub: 1,
            anticipatePin: 1,
          },
        });
      }

      // ===== HEADER: Show on scroll past intro =====
      if (header) {
        header.style.opacity = '0';
        header.style.transition = 'opacity 0.3s ease';
      }
    </script>
  </body>
</html>
